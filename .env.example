# AIForum 生产环境配置
# 复制此文件为 .env.prod 并填入真实值

# ===========================================
# 数据库配置
# ===========================================
MYSQL_ROOT_PASSWORD=YourSecureRootPassword123!
MYSQL_USER=aiforum
MYSQL_PASSWORD=YourSecurePassword123!

# ===========================================
# 应用配置
# ===========================================
# JWT密钥（至少32字符，用于Token加密）
# 生成命令: openssl rand -hex 32
SECRET_KEY=your-secret-key-at-least-32-characters-long

# ===========================================
# AI配置
# ===========================================
# 智谱AI API Key（支持5个Key轮换使用）
ZHIPU_API_KEY_1=your_zhipu_api_key_1_here
ZHIPU_API_KEY_2=your_zhipu_api_key_2_here
ZHIPU_API_KEY_3=your_zhipu_api_key_3_here
ZHIPU_API_KEY_4=your_zhipu_api_key_4_here
ZHIPU_API_KEY_5=your_zhipu_api_key_5_here

# OCR API Key（可选）
OCR_API_KEY=your_ocr_api_key_here

# ===========================================
# 其他配置
# ===========================================
DEBUG=false
